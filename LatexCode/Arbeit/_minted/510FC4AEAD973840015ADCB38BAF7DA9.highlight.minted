\PYG{g+gu}{section}\PYG{+w}{ }\PYG{l+s}{‹The I/O automata of Lynch and Tuttle in HOLCF›}

\PYG{k}{theory}\PYG{+w}{ }\PYG{n}{Automata}
\PYG{k+kp}{imports}\PYG{+w}{ }\PYG{n}{Asig}
\PYG{k}{begin}

\PYG{k}{default\PYGZus{}sort}\PYG{+w}{ }\PYG{n}{type}

\PYG{k}{type\PYGZus{}synonym}\PYG{+w}{ }\PYG{o}{(}\PYG{n+nType}{\PYGZsq{}a}\PYG{o}{,}\PYG{+w}{ }\PYG{n+nType}{\PYGZsq{}s}\PYG{o}{)}\PYG{+w}{ }\PYG{n}{transition}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}\PYGZsq{}s × \PYGZsq{}a × \PYGZsq{}s\PYGZdq{}}
\PYG{k}{type\PYGZus{}synonym}\PYG{+w}{ }\PYG{o}{(}\PYG{n+nType}{\PYGZsq{}a}\PYG{o}{,}\PYG{+w}{ }\PYG{n+nType}{\PYGZsq{}s}\PYG{o}{)}\PYG{+w}{ }\PYG{n}{ioa}\PYG{+w}{ }\PYG{o}{=}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}\PYGZsq{}a signature × \PYGZsq{}s set × (\PYGZsq{}a, \PYGZsq{}s)transition set × \PYGZsq{}a set set × \PYGZsq{}a set set\PYGZdq{}}


\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{‹IO automata›}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{asig\PYGZus{}of}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}a signature\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}asig\PYGZus{}of = fst\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{starts\PYGZus{}of}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}s set\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}starts\PYGZus{}of = fst ∘ snd\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ (\PYGZsq{}a, \PYGZsq{}s) transition set\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}trans\PYGZus{}of = fst ∘ snd ∘ snd\PYGZdq{}}

\PYG{k}{abbreviation}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}syn}\PYG{+w}{  }\PYG{o}{(}\PYG{l+s}{‹\PYGZus{} ─\PYGZus{}─\PYGZus{}→ \PYGZus{}›}\PYG{+w}{ }\PYG{o}{[}\PYG{n}{81}\PYG{o}{,}\PYG{+w}{ }\PYG{n}{81}\PYG{o}{,}\PYG{+w}{ }\PYG{n}{81}\PYG{o}{,}\PYG{+w}{ }\PYG{n}{81}\PYG{o}{]}\PYG{+w}{ }\PYG{n}{100}\PYG{o}{)}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}s ─a─A→ t ≡ (s, a, t) ∈ trans\PYGZus{}of A\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{wfair\PYGZus{}of}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}a set set\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}wfair\PYGZus{}of = fst ∘ snd ∘ snd ∘ snd\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{sfair\PYGZus{}of}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}a set set\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}sfair\PYGZus{}of = snd ∘ snd ∘ snd ∘ snd\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{is\PYGZus{}asig\PYGZus{}of}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}is\PYGZus{}asig\PYGZus{}of A = is\PYGZus{}asig (asig\PYGZus{}of A)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{is\PYGZus{}starts\PYGZus{}of}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}is\PYGZus{}starts\PYGZus{}of A ⟷ starts\PYGZus{}of A ≠ \PYGZob{}\PYGZcb{}\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{is\PYGZus{}trans\PYGZus{}of}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}is\PYGZus{}trans\PYGZus{}of A ⟷}
\PYG{l+s}{    (∀triple. triple ∈ trans\PYGZus{}of A ⟶ fst (snd triple) ∈ actions (asig\PYGZus{}of A))\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{input\PYGZus{}enabled}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}input\PYGZus{}enabled A ⟷}
\PYG{l+s}{    (∀a. a ∈ inputs (asig\PYGZus{}of A) ⟶ (∀s1. ∃s2. (s1, a, s2) ∈ trans\PYGZus{}of A))\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{IOA}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}IOA A ⟷}
\PYG{l+s}{    is\PYGZus{}asig\PYGZus{}of A ∧}
\PYG{l+s}{    is\PYGZus{}starts\PYGZus{}of A ∧}
\PYG{l+s}{    is\PYGZus{}trans\PYGZus{}of A ∧}
\PYG{l+s}{    input\PYGZus{}enabled A\PYGZdq{}}

\PYG{k}{abbreviation}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}act A ≡ actions (asig\PYGZus{}of A)\PYGZdq{}}
\PYG{k}{abbreviation}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}ext A ≡ externals (asig\PYGZus{}of A)\PYGZdq{}}
\PYG{k}{abbreviation}\PYG{+w}{ }\PYG{n}{int}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}int A ≡ internals (asig\PYGZus{}of A)\PYGZdq{}}
\PYG{k}{abbreviation}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}inp A ≡ inputs (asig\PYGZus{}of A)\PYGZdq{}}
\PYG{k}{abbreviation}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}out A ≡ outputs (asig\PYGZus{}of A)\PYGZdq{}}
\PYG{k}{abbreviation}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}local A ≡ locals (asig\PYGZus{}of A)\PYGZdq{}}


\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{‹invariants›}

\PYG{k}{inductive}\PYG{+w}{ }\PYG{n}{reachable}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}s ⇒ bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{for}\PYG{+w}{ }\PYG{n}{C}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa\PYGZdq{}}
\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{n}{reachable\PYGZus{}0}\PYG{o}{:}\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}s ∈ starts\PYGZus{}of C ⟹ reachable C s\PYGZdq{}}
\PYG{o}{|}\PYG{+w}{ }\PYG{n}{reachable\PYGZus{}n}\PYG{o}{:}\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}reachable C s ⟹ (s, a, t) ∈ trans\PYGZus{}of C ⟹ reachable C t\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{invariant}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}[(\PYGZsq{}a, \PYGZsq{}s) ioa, \PYGZsq{}s ⇒ bool] ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}invariant A P ⟷ (∀s. reachable A s ⟶ P s)\PYGZdq{}}


\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{‹Parallel composition›}

\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{‹Binary composition of action signatures and automata›}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{compatible}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ (\PYGZsq{}a, \PYGZsq{}t) ioa ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}compatible A B ⟷}
\PYG{l+s}{    out A ∩ out B = \PYGZob{}\PYGZcb{} ∧}
\PYG{l+s}{    int A ∩ act B = \PYGZob{}\PYGZcb{} ∧}
\PYG{l+s}{    int B ∩ act A = \PYGZob{}\PYGZcb{}\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{asig\PYGZus{}comp}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}\PYGZsq{}a signature ⇒ \PYGZsq{}a signature ⇒ \PYGZsq{}a signature\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}asig\PYGZus{}comp a1 a2 =}
\PYG{l+s}{     (((inputs a1 ∪ inputs a2) \PYGZhy{} (outputs a1 ∪ outputs a2),}
\PYG{l+s}{       (outputs a1 ∪ outputs a2),}
\PYG{l+s}{       (internals a1 ∪ internals a2)))\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{par}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ (\PYGZsq{}a, \PYGZsq{}t) ioa ⇒ (\PYGZsq{}a, \PYGZsq{}s * \PYGZsq{}t) ioa\PYGZdq{}}\PYG{+w}{  }\PYG{o}{(}\PYG{k+kp}{infixr}\PYG{+w}{ }\PYG{l+s}{‹∥›}\PYG{+w}{ }\PYG{n}{10}\PYG{o}{)}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(A ∥ B) =}
\PYG{l+s}{    (asig\PYGZus{}comp (asig\PYGZus{}of A) (asig\PYGZus{}of B),}
\PYG{l+s}{     \PYGZob{}pr. fst pr ∈ starts\PYGZus{}of A ∧ snd pr ∈ starts\PYGZus{}of B\PYGZcb{},}
\PYG{l+s}{     \PYGZob{}tr.}
\PYG{l+s}{        let}
\PYG{l+s}{          s = fst tr;}
\PYG{l+s}{          a = fst (snd tr);}
\PYG{l+s}{          t = snd (snd tr)}
\PYG{l+s}{        in}
\PYG{l+s}{          (a ∈ act A ∨ a ∈ act B) ∧}
\PYG{l+s}{          (if a ∈ act A then (fst s, a, fst t) ∈ trans\PYGZus{}of A}
\PYG{l+s}{           else fst t = fst s) ∧}
\PYG{l+s}{          (if a ∈ act B then (snd s, a, snd t) ∈ trans\PYGZus{}of B}
\PYG{l+s}{           else snd t = snd s)\PYGZcb{},}
\PYG{l+s}{      wfair\PYGZus{}of A ∪ wfair\PYGZus{}of B,}
\PYG{l+s}{      sfair\PYGZus{}of A ∪ sfair\PYGZus{}of B)\PYGZdq{}}


\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{‹Hiding›}

\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{‹Hiding and restricting›}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{restrict\PYGZus{}asig}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}\PYGZsq{}a signature ⇒ \PYGZsq{}a set ⇒ \PYGZsq{}a signature\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}restrict\PYGZus{}asig asig actns =}
\PYG{l+s}{    (inputs asig ∩ actns,}
\PYG{l+s}{     outputs asig ∩ actns,}
\PYG{l+s}{     internals asig ∪ (externals asig \PYGZhy{} actns))\PYGZdq{}}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{‹}
\PYG{l+s}{  Notice that for ‹wfair\PYGZus{}of› and ‹sfair\PYGZus{}of› nothing has to be changed, as}
\PYG{l+s}{  changes from the outputs to the internals does not touch the locals as a}
\PYG{l+s}{  whole, which is of importance for fairness only.}
\PYG{l+s}{›}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{restrict}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}a set ⇒ (\PYGZsq{}a, \PYGZsq{}s) ioa\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}restrict A actns =}
\PYG{l+s}{    (restrict\PYGZus{}asig (asig\PYGZus{}of A) actns,}
\PYG{l+s}{     starts\PYGZus{}of A,}
\PYG{l+s}{     trans\PYGZus{}of A,}
\PYG{l+s}{     wfair\PYGZus{}of A,}
\PYG{l+s}{     sfair\PYGZus{}of A)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{hide\PYGZus{}asig}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}\PYGZsq{}a signature ⇒ \PYGZsq{}a set ⇒ \PYGZsq{}a signature\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}hide\PYGZus{}asig asig actns =}
\PYG{l+s}{    (inputs asig \PYGZhy{} actns,}
\PYG{l+s}{     outputs asig \PYGZhy{} actns,}
\PYG{l+s}{     internals asig ∪ actns)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{hide}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}a set ⇒ (\PYGZsq{}a, \PYGZsq{}s) ioa\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}hide A actns =}
\PYG{l+s}{    (hide\PYGZus{}asig (asig\PYGZus{}of A) actns,}
\PYG{l+s}{     starts\PYGZus{}of A,}
\PYG{l+s}{     trans\PYGZus{}of A,}
\PYG{l+s}{     wfair\PYGZus{}of A,}
\PYG{l+s}{     sfair\PYGZus{}of A)\PYGZdq{}}


\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{‹Renaming›}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{rename\PYGZus{}set}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}\PYGZsq{}a set ⇒ (\PYGZsq{}c ⇒ \PYGZsq{}a option) ⇒ \PYGZsq{}c set\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}rename\PYGZus{}set A ren = \PYGZob{}b. ∃x. Some x = ren b ∧ x ∈ A\PYGZcb{}\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{rename}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}b) ioa ⇒ (\PYGZsq{}c ⇒ \PYGZsq{}a option) ⇒ (\PYGZsq{}c, \PYGZsq{}b) ioa\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}rename ioa ren =}
\PYG{l+s}{    ((rename\PYGZus{}set (inp ioa) ren,}
\PYG{l+s}{      rename\PYGZus{}set (out ioa) ren,}
\PYG{l+s}{      rename\PYGZus{}set (int ioa) ren),}
\PYG{l+s}{     starts\PYGZus{}of ioa,}
\PYG{l+s}{     \PYGZob{}tr.}
\PYG{l+s}{        let}
\PYG{l+s}{          s = fst tr;}
\PYG{l+s}{          a = fst (snd tr);}
\PYG{l+s}{          t = snd (snd tr)}
\PYG{l+s}{        in ∃x. Some x = ren a ∧ s ─x─ioa→ t\PYGZcb{},}
\PYG{l+s}{     \PYGZob{}rename\PYGZus{}set s ren | s. s ∈ wfair\PYGZus{}of ioa\PYGZcb{},}
\PYG{l+s}{     \PYGZob{}rename\PYGZus{}set s ren | s. s ∈ sfair\PYGZus{}of ioa\PYGZcb{})\PYGZdq{}}


\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{‹Fairness›}

\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{‹Enabledness of actions and action sets›}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{enabled}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}a ⇒ \PYGZsq{}s ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}enabled A a s ⟷ (∃t. s ─a─A→ t)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{Enabled}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}a set ⇒ \PYGZsq{}s ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}Enabled A W s ⟷ (∃w ∈ W. enabled A w s)\PYGZdq{}}


\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{‹Action set keeps enabled until probably disabled by itself.›}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{en\PYGZus{}persistent}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}a set ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}en\PYGZus{}persistent A W ⟷}
\PYG{l+s}{    (∀s a t. Enabled A W s ∧ a ∉ W ∧ s ─a─A→ t ⟶ Enabled A W t)\PYGZdq{}}


\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{‹Post conditions for actions and action sets.›}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{was\PYGZus{}enabled}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}a ⇒ \PYGZsq{}s ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}was\PYGZus{}enabled A a t ⟷ (∃s. s ─a─A→ t)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{set\PYGZus{}was\PYGZus{}enabled}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ \PYGZsq{}a set ⇒ \PYGZsq{}s ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}set\PYGZus{}was\PYGZus{}enabled A W t ⟷ (∃w ∈ W. was\PYGZus{}enabled A w t)\PYGZdq{}}


\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{‹Constraints for fair IOA.›}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{fairIOA}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}fairIOA A ⟷ (∀S ∈ wfair\PYGZus{}of A. S ⊆ local A) ∧ (∀S ∈ sfair\PYGZus{}of A. S ⊆ local A)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{input\PYGZus{}resistant}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}a, \PYGZsq{}s) ioa ⇒ bool\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}input\PYGZus{}resistant A ⟷}
\PYG{l+s}{    (∀W ∈ sfair\PYGZus{}of A. ∀s a t.}
\PYG{l+s}{      reachable A s ∧ reachable A t ∧ a ∈ inp A ∧}
\PYG{l+s}{      Enabled A W s ∧ s ─a─A→ t ⟶ Enabled A W t)\PYGZdq{}}


\PYG{k}{declare}\PYG{+w}{ }\PYG{n}{split\PYGZus{}paired\PYGZus{}Ex}\PYG{+w}{ }\PYG{o}{[}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{del}\PYG{o}{]}

