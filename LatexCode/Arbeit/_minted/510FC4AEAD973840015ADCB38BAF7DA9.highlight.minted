\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}‹asig\PYGZus{}of›, ‹starts\PYGZus{}of›, ‹trans\PYGZus{}of›\PYGZdq{}}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{ioa\PYGZus{}triple\PYGZus{}proj}\PYG{o}{:}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}asig\PYGZus{}of (x, y, z, w, s) = x ∧}
\PYG{l+s}{   starts\PYGZus{}of (x, y, z, w, s) = y ∧}
\PYG{l+s}{   trans\PYGZus{}of (x, y, z, w, s) = z ∧}
\PYG{l+s}{   wfair\PYGZus{}of (x, y, z, w, s) = w ∧}
\PYG{l+s}{   sfair\PYGZus{}of (x, y, z, w, s) = s\PYGZdq{}}
\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{ioa\PYGZus{}projections}\PYG{o}{)}

