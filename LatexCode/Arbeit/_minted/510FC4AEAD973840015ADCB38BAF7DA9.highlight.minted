\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}a ∉ act A ⟹ a ∈ act B ⟹}
\PYG{l+s}{  (snd s, a, snd t) ∈ trans\PYGZus{}of B ⟹}
\PYG{l+s}{  fst s = fst t ⟹}
\PYG{l+s}{  (s, a, t) ∈ trans\PYGZus{}of (A ∥ B)\PYGZdq{}}
\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{Let\PYGZus{}def}\PYG{+w}{ }\PYG{n}{par\PYGZus{}def}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}def}\PYG{o}{)}

\PYG{k}{lemmas}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}defs1}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}AB}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}A\PYGZus{}notB}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}notA\PYGZus{}B}
\PYG{+w}{  }\PYG{k+kp}{and}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}defs2}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}A\PYGZus{}proj}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}B\PYGZus{}proj}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}A\PYGZus{}proj2}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}B\PYGZus{}proj2}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}AB\PYGZus{}proj}


\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}par4}\PYG{o}{:}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}(s, a, t) ∈ trans\PYGZus{}of (A ∥ B ∥ C ∥ D) ⟷}
\PYG{l+s}{    ((a ∈ actions (asig\PYGZus{}of A) ∨ a ∈ actions (asig\PYGZus{}of B) ∨ a ∈ actions (asig\PYGZus{}of C) ∨}
\PYG{l+s}{      a ∈ actions (asig\PYGZus{}of D)) ∧}
\PYG{l+s}{     (if a ∈ actions (asig\PYGZus{}of A)}
\PYG{l+s}{      then (fst s, a, fst t) ∈ trans\PYGZus{}of A}
\PYG{l+s}{      else fst t = fst s) ∧}
\PYG{l+s}{     (if a ∈ actions (asig\PYGZus{}of B)}
\PYG{l+s}{      then (fst (snd s), a, fst (snd t)) ∈ trans\PYGZus{}of B}
\PYG{l+s}{      else fst (snd t) = fst (snd s)) ∧}
\PYG{l+s}{     (if a ∈ actions (asig\PYGZus{}of C)}
\PYG{l+s}{      then (fst (snd (snd s)), a, fst (snd (snd t))) ∈ trans\PYGZus{}of C}
\PYG{l+s}{      else fst (snd (snd t)) = fst (snd (snd s))) ∧}
\PYG{l+s}{     (if a ∈ actions (asig\PYGZus{}of D)}
\PYG{l+s}{      then (snd (snd (snd s)), a, snd (snd (snd t))) ∈ trans\PYGZus{}of D}
\PYG{l+s}{      else snd (snd (snd t)) = snd (snd (snd s))))\PYGZdq{}}
\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{par\PYGZus{}def}\PYG{+w}{ }\PYG{n}{actions\PYGZus{}asig\PYGZus{}comp}\PYG{+w}{ }\PYG{n}{prod\PYGZus{}eq\PYGZus{}iff}\PYG{+w}{ }\PYG{n}{Let\PYGZus{}def}\PYG{+w}{ }\PYG{n}{ioa\PYGZus{}projections}\PYG{o}{)}


