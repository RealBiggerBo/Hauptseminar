\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{auto}\PYG{+w}{ }\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{is\PYGZus{}trans\PYGZus{}of\PYGZus{}def}\PYG{+w}{ }\PYG{n}{actions\PYGZus{}def}\PYG{+w}{ }\PYG{n}{is\PYGZus{}asig\PYGZus{}def}\PYG{o}{)}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{starts\PYGZus{}of\PYGZus{}par}\PYG{o}{:}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}starts\PYGZus{}of (A ∥ B) = \PYGZob{}p. fst p ∈ starts\PYGZus{}of A ∧ snd p ∈ starts\PYGZus{}of B\PYGZcb{}\PYGZdq{}}
\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{par\PYGZus{}def}\PYG{+w}{ }\PYG{n}{ioa\PYGZus{}projections}\PYG{o}{)}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}par}\PYG{o}{:}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}trans\PYGZus{}of(A ∥ B) =}
\PYG{l+s}{    \PYGZob{}tr.}
\PYG{l+s}{      let}
\PYG{l+s}{        s = fst tr;}
\PYG{l+s}{        a = fst (snd tr);}
\PYG{l+s}{        t = snd (snd tr)}
\PYG{l+s}{      in}
\PYG{l+s}{        (a ∈ act A ∨ a ∈ act B) ∧}
\PYG{l+s}{        (if a ∈ act A then (fst s, a, fst t) ∈ trans\PYGZus{}of A}
\PYG{l+s}{         else fst t = fst s) ∧}
\PYG{l+s}{        (if a ∈ act B then (snd s, a, snd t) ∈ trans\PYGZus{}of B}
\PYG{l+s}{         else snd t = snd s)\PYGZcb{}\PYGZdq{}}
\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{par\PYGZus{}def}\PYG{+w}{ }\PYG{n}{ioa\PYGZus{}projections}\PYG{o}{)}


