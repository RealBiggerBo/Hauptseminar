\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{Let\PYGZus{}def}\PYG{+w}{ }\PYG{n}{par\PYGZus{}def}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}def}\PYG{o}{)}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}B\PYGZus{}proj2}\PYG{o}{:}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(s, a, t) ∈ trans\PYGZus{}of (A ∥ B) ⟹ a ∉ act B ⟹ snd s = snd t\PYGZdq{}}
\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{Let\PYGZus{}def}\PYG{+w}{ }\PYG{n}{par\PYGZus{}def}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}def}\PYG{o}{)}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}AB\PYGZus{}proj}\PYG{o}{:}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(s, a, t) ∈ trans\PYGZus{}of (A ∥ B) ⟹ a ∈ act A ∨ a ∈ act B\PYGZdq{}}
\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{Let\PYGZus{}def}\PYG{+w}{ }\PYG{n}{par\PYGZus{}def}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}def}\PYG{o}{)}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}AB}\PYG{o}{:}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}a ∈ act A ⟹ a ∈ act B ⟹}
\PYG{l+s}{  (fst s, a, fst t) ∈ trans\PYGZus{}of A ⟹}
\PYG{l+s}{  (snd s, a, snd t) ∈ trans\PYGZus{}of B ⟹}
\PYG{l+s}{  (s, a, t) ∈ trans\PYGZus{}of (A ∥ B)\PYGZdq{}}
\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{Let\PYGZus{}def}\PYG{+w}{ }\PYG{n}{par\PYGZus{}def}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}def}\PYG{o}{)}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}A\PYGZus{}notB}\PYG{o}{:}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}a ∈ act A ⟹ a ∉ act B ⟹}
\PYG{l+s}{  (fst s, a, fst t) ∈ trans\PYGZus{}of A ⟹}
\PYG{l+s}{  snd s = snd t ⟹}
\PYG{l+s}{  (s, a, t) ∈ trans\PYGZus{}of (A ∥ B)\PYGZdq{}}
\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{Let\PYGZus{}def}\PYG{+w}{ }\PYG{n}{par\PYGZus{}def}\PYG{+w}{ }\PYG{n}{trans\PYGZus{}of\PYGZus{}def}\PYG{o}{)}

