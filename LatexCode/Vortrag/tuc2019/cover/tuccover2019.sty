% Abmessungen
\define@choicekey*{tuccover2019.sty}{size}[\val\nr]{a4,a5}{%
  \ifcase\nr\relax
    \setlength{\tucc@ver@logosep}{10.3mm}
    \setlength{\tucc@ver@logowidth}{47.0mm}
    \setlength{\tucc@ver@rulethickness}{0.7pt}
    \def\tucc@ver@front@size{14.0}
    % Laut CI-Vorgabe sollen es 21pt sein, aber das passt nicht zu den Mustern.
    % 18pt erscheinen passender.
    %\def\tucc@ver@front@skip{21.0}
    \def\tucc@ver@front@skip{18.0}
    \def\tucc@ver@back@size{12.0}
    \def\tucc@ver@back@skip{18.0}
  \or
    \setlength{\tucc@ver@logosep}{7.0mm}
    \setlength{\tucc@ver@logowidth}{32.0mm}
    \setlength{\tucc@ver@rulethickness}{0.7pt}
    % Laut CI-Vorgabe sollen es 14pt sein, aber das passt nicht zu den Mustern.
    % 9pt erscheinen passender.
    %\def\tucc@ver@front@size{14.0}
    \def\tucc@ver@front@size{9.0}
    % Laut CI-Vorgabe sollen es 21pt sein, aber das passt nicht zu den Mustern.
    % 12pt erscheinen passender.
    %\def\tucc@ver@front@skip{21.0}
    \def\tucc@ver@front@skip{12.0}
    % Laut CI-Vorgabe sollen es 10pt und 13pt sein, aber das passt nicht zu den
    % Mustern. 6pt und 8pt passen besser.
    %\def\tucc@ver@back@size{10.0}
    %\def\tucc@ver@back@skip{13.0}
    \def\tucc@ver@back@size{6.0}
    \def\tucc@ver@back@skip{8.0}
  \fi
}

