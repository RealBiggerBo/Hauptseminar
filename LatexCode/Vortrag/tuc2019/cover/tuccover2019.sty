% Titelzeilen
\def\tucc@ver@reporttitle@content{}
\newcommand{\tucfrontcoverreporttitle}[3]%
{
  \def\tucc@ver@reporttitle@content{%
    \hbox to \hsize{\strut\bfseries\smash{#1}\hfil}\vskip 0pt%
    \hbox to \hsize{\strut\smash{#2}\hfil}\vskip 0pt%
    \hbox to \hsize{\strut\smash{#3}\hfil}%
  }
}

\newcommand{\tucc@ver@reporttitle@block}%
{%
  \begin{picture}(\strip@pt\paperwidth, \strip@pt\dimexpr\tucc@ver@reporttitleheight)
  \setlength{\@tempdima}{0.85\tucc@ver@logoheight}
  \edef\tucc@ver@titleheight{\the\@tempdima}
  \setlength{\@tempdima}{0.5\tucc@ver@logosep}
  \put(\strip@pt\dimexpr\tucc@ver@columnindent, \strip@pt\@tempdima){%
    \makebox(\strip@pt\dimexpr\tucc@ver@columnwidth, \strip@pt\dimexpr\tucc@ver@titleheight)[tl]{%
      \setlength{\hsize}{\tucc@ver@columnwidth}%
      \fontsize{\tucc@ver@front@size}{\tucc@ver@front@skip}\selectfont%
      \vbox to 0.85\tucc@ver@logoheight{%
        \vfill%
        \tucc@ver@reporttitle@content%
        \vfill%
      }%
    }%
  }
  \end{picture}%
}

\newenvironment{tucfrontcoverreport@content}%
{%
  \tucc@ver@calcfront%
  \begingroup%
  \setlength{\@tempdima}{\paperheight}%
  \addtolength{\@tempdima}{-3\tucc@ver@logosep}%
  \addtolength{\@tempdima}{-\tucc@ver@logoheight}%
  \addtolength{\@tempdima}{-\tucc@ver@reporttitleheight}%
  \locbox\@tempbox%
  \setbox\@tempbox\vbox\bgroup%
  \hsize=\paperwidth%
  \vsize=\@tempdima%
  \ignorespaces%
}
{%
  \egroup%
  \vbox to \paperheight{%
    \hsize=\paperwidth%
    \hbox{\tucc@ver@headline@block}\vskip-1pt%
    \hbox{\tucc@ver@reporttitle@block}\vskip-1pt%
    \setlength{\@tempdima}{\paperheight}%
    \addtolength{\@tempdima}{-3\tucc@ver@logosep}%
    \addtolength{\@tempdima}{-\tucc@ver@logoheight}%
    \addtolength{\@tempdima}{-\tucc@ver@reporttitleheight}%
    \edef\tucc@ver@totalheight{\the\@tempdima}%
    \hbox{\begin{picture}(\strip@pt\paperwidth, \strip@pt\dimexpr\tucc@ver@totalheight)
    \put(0, 0){\parbox[b][\tucc@ver@totalheight][t]{\paperwidth}{\unvbox\@tempbox}}%
    \end{picture}}%
  }%
  \endgroup%
}

\newenvironment{tucfrontcoverreport}%
{%
  \tucc@ver%
  \tucfrontcoverreport@content%
}
{%
  \endtucfrontcoverreport@content%
  \endtucc@ver%
}

