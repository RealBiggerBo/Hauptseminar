% Titelei
\newcommand{\tucfrontcoverbooktitle}[2]%
{
  \vskip\tucc@ver@logosep
  \hbox to \hsize{%
    \hfill%
    \setlength{\@tempdima}{\hsize}%
    \addtolength{\@tempdima}{-2\tucc@ver@logosep}%
    \begin{minipage}{\@tempdima}
    \color{white}
    \begin{center}
    \fontsize{14}{16}\selectfont #1\par\bigskip
    \fontsize{25}{30}\selectfont #2\par
    \end{center}
    \end{minipage}
    \hfill%
  }
  \vfill
  \vskip\tucc@ver@logosep
}


%
% Rückseite
%

\newcommand{\tucc@ver@calcback}
{%
  \tucc@ver@calc%
%
  % Einzug der rechten Spalte
  % = linker Rand + Schutzraum + Logobreite
  \setlength{\@tempdima}{0pt}%
  \addtolength{\@tempdima}{2\tucc@ver@logosep}%
  \addtolength{\@tempdima}{\tucc@ver@logowidth}%
  \edef\tucc@ver@columnindent{\the\@tempdima}%
%
  % Breite der rechten Spalte
  % = Papierbreite - Einzug - rechter Rand
  \setlength{\@tempdima}{\paperwidth}%
  \addtolength{\@tempdima}{-\tucc@ver@columnindent}%
  \addtolength{\@tempdima}{-\tucc@ver@logosep}%
  \edef\tucc@ver@columnwidth{\the\@tempdima}%
}

\newenvironment{tucbackcover@content}%
{%
  \tucc@ver@calcback%
  \begingroup%
  \fontsize{\tucc@ver@back@size}{\tucc@ver@back@skip}\selectfont%
  \setlength{\@tempdima}{\paperwidth}%
  \addtolength{\@tempdima}{-2\tucc@ver@logosep}%
  \edef\tucc@ver@bodywidth{\the\@tempdima}%
  \setlength{\@tempdima}{\paperheight}%
  \addtolength{\@tempdima}{-5\tucc@ver@logosep}%
  \addtolength{\@tempdima}{-\tucc@ver@logoheight}%
  \edef\tucc@ver@bodyheight{\the\@tempdima}%
  \locbox\@tempbox%
  \setbox\@tempbox\vbox\bgroup%
  \hsize=\tucc@ver@bodywidth\relax%
  \vsize=\tucc@ver@bodyheight\relax%
  \ignorespaces%
}
{%
  \egroup%
  \vbox to \paperheight{%
    \hsize=\paperwidth%
    \hbox{%
      \begingroup%
      \fboxsep=0pt%
      \setlength{\@tempdima}{3\tucc@ver@logosep}%
      \addtolength{\@tempdima}{\tucc@ver@logoheight}%
      \colorbox{tuccolor}{\vbox to \@tempdima{\hbox to \hsize{\hfill}\vfill}}%
      \endgroup%
    }\vskip-1pt%
    \vskip\tucc@ver@logosep%
    \hbox to \paperwidth{%
      \hfill%
      \parbox[b][\tucc@ver@bodyheight][b]{\tucc@ver@bodywidth}{\unvbox\@tempbox}%
      \hfill%
    }%
    \vskip\tucc@ver@logosep%
  }%
  \endgroup%
}

