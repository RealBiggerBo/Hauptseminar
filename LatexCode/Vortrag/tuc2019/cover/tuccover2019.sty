      \colorbox{tuccolor}{\makebox(\strip@pt\paperwidth, \strip@pt\paperheight)[t]{\null}}%
    }%
    \end{picture}}\vskip-1pt%
    \hbox{\tucc@ver@headline@block}\vskip-1pt%
