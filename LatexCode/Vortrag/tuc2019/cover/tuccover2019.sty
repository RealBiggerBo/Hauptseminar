% Einzüge berechnen.
\newcommand{\tucc@ver@calc}
{%
  % Skalierung der picture-Umgebung einstellen.
  \setlength{\unitlength}{1pt}%
%
  % Höhe des Kopfblocks
  % = Logohöhe + 3 * Logoschutzraum
  \setlength{\@tempdima}{\tucc@ver@logoheight}%
  \addtolength{\@tempdima}{3\tucc@ver@logosep}%
  \edef\tucc@ver@headheight{\the\@tempdima}%
}

\newcommand{\tucc@ver@calcfront}
{%
  \tucc@ver@calc%
%
  % Abstand des Logos zur Unterkante
  \setlength{\@tempdima}{2\tucc@ver@logosep}%
  \edef\tucc@ver@headyoffset{\the\@tempdima}%
%
  % Einzug der Kopfzeilen
  % = linker Rand + 2 * Schutzraum + Logobreite
  \setlength{\@tempdima}{0pt}%
  \addtolength{\@tempdima}{3\tucc@ver@logosep}%
  \addtolength{\@tempdima}{\tucc@ver@logowidth}%
  \edef\tucc@ver@columnindent{\the\@tempdima}%
%
  % Länge der Kopfzeilen
  % = Papierbreite - Einzug - rechter Rand
  \setlength{\@tempdima}{\paperwidth}%
  \addtolength{\@tempdima}{-\tucc@ver@columnindent}%
  \addtolength{\@tempdima}{-\tucc@ver@logosep}%
  \edef\tucc@ver@columnwidth{\the\@tempdima}%
%
  % Höhe des Titelblocks
  % = 0.85 * Logohöhe + Logoschutzraum
  \setlength{\@tempdima}{0.85\tucc@ver@logoheight}%
  \addtolength{\@tempdima}{\tucc@ver@logosep}%
  \edef\tucc@ver@reporttitleheight{\the\@tempdima}%
}


%
% Allgemeine Vorderseite
%

\def\tucc@ver@headline@content{}
\newcommand{\tucfrontcoverhead}[4]%
{
  \def\tucc@ver@headline@content{%
    \hbox to \hsize{\strut\bfseries\smash{#1}\hfil}\vfil%
    \hbox to \hsize{\strut\smash{#2}\hfil}\vfil%
    \hbox to \hsize{\strut\smash{#3}\hfil}\vfil%
    \hbox to \hsize{\strut\smash{#4}\hfil}%
  }
}

\newcommand\tucc@ver@headline@block%
{%
  \begin{picture}(\strip@pt\paperwidth, \strip@pt\dimexpr\tucc@ver@headheight)
  \color{white}%
  \put(0, 0){%
    \begingroup%
    \fboxsep=0pt%
    \colorbox{tuccolor}{\vbox to \tucc@ver@headheight{\hskip\paperwidth\vfill}}%
    \endgroup%
  }
  \put(\strip@pt\tucc@ver@logosep, \strip@pt\dimexpr\tucc@ver@headyoffset){%
    \makebox(\strip@pt\tucc@ver@logowidth, \strip@pt\tucc@ver@logoheight){%
      \includegraphics[width=\tucc@ver@logowidth,height=\tucc@ver@logoheight]{\tucc@ver@frontlogo}%
    }%
  }
  \setlength{\@tempdima}{2\tucc@ver@logosep}
  \addtolength{\@tempdima}{\tucc@ver@logowidth}
  \put(\strip@pt\@tempdima, \strip@pt\dimexpr\tucc@ver@headyoffset){%
    \hbox to 0pt{\hss\rule{\tucc@ver@rulethickness}{\tucc@ver@logoheight}\hss}%
  }
  \put(\strip@pt\dimexpr\tucc@ver@columnindent, \strip@pt\dimexpr\tucc@ver@headyoffset){%
    \makebox(\strip@pt\dimexpr\tucc@ver@columnwidth, \strip@pt\dimexpr\tucc@ver@logoheight)[tl]{%
      \setlength{\hsize}{\tucc@ver@columnwidth}%
      \fontsize{\tucc@ver@front@size}{\tucc@ver@front@skip}\selectfont%
      \vbox to \tucc@ver@logoheight{\tucc@ver@headline@content}%
    }%
  }
  \end{picture}%
}


