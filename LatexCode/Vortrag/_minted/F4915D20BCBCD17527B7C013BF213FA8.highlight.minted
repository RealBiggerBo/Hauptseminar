\PYG{k}{datatype}\PYG{+w}{ }\PYG{o}{(}\PYG{n+nType}{\PYGZsq{}proc}\PYG{o}{,}\PYG{+w}{ }\PYG{n+nType}{\PYGZsq{}msg}\PYG{o}{)}\PYG{+w}{ }\PYG{n}{event}
