\PYG{+w}{  }\PYG{k+kp}{shows}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}∃msgs states sent new\PYGZus{}state.}
\PYG{l+s}{          execute step init procs events msgs states ∧}
\PYG{l+s}{          proc ∈ procs ∧}
\PYG{l+s}{          valid\PYGZus{}event event proc msgs ∧}
\PYG{l+s}{          step proc (states proc) event = (new\PYGZus{}state, sent) ∧}
\PYG{l+s}{          msgs\PYGZsq{} = msgs ∪ ((λmsg. (proc, msg)) ` sent) ∧}
\PYG{l+s}{          states\PYGZsq{} = states (proc := new\PYGZus{}state)\PYGZdq{}}
