\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}execute step init procs (events @ [(proc, event)]) msgs\PYGZsq{} states\PYGZsq{}\PYGZdq{}}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{execute\PYGZus{}step}\PYG{o}{:}
