\PYG{k}{fun}\PYG{+w}{ }\PYG{n}{valid\PYGZus{}event}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}proc, \PYGZsq{}msg) event ⇒ \PYGZsq{}proc ⇒}
\PYG{l+s}{                    (\PYGZsq{}proc × (\PYGZsq{}proc, \PYGZsq{}msg) send) set ⇒ bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
