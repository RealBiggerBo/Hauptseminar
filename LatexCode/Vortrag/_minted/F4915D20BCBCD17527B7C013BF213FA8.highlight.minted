\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}valid\PYGZus{}event (Receive sender msg) proc msgs = ((sender, Send proc msg) ∈ msgs)\PYGZdq{}}\PYG{+w}{ }\PYG{o}{|}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}valid\PYGZus{}event \PYGZus{} \PYGZus{} \PYGZus{} = True\PYGZdq{}}

\PYG{k}{inductive}\PYG{+w}{ }\PYG{n}{execute}\PYG{+w}{ }\PYG{o}{::}
\PYG{+w}{    }\PYG{l+s}{\PYGZdq{}(\PYGZsq{}proc, \PYGZsq{}state, \PYGZsq{}msg) step\PYGZus{}func ⇒ (\PYGZsq{}proc ⇒ \PYGZsq{}state) ⇒ \PYGZsq{}proc set ⇒}
\PYG{l+s}{     (\PYGZsq{}proc × (\PYGZsq{}proc, \PYGZsq{}msg) event) list ⇒}
\PYG{l+s}{     (\PYGZsq{}proc × (\PYGZsq{}proc, \PYGZsq{}msg) send) set ⇒ (\PYGZsq{}proc ⇒ \PYGZsq{}state) ⇒ bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}execute step init procs [] \PYGZob{}\PYGZcb{} init\PYGZdq{}}\PYG{+w}{ }\PYG{o}{|}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}⟦execute step init procs events msgs states;}
\PYG{l+s}{    proc ∈ procs;}
\PYG{l+s}{    valid\PYGZus{}event event proc msgs;}
\PYG{l+s}{    step proc (states proc) event = (new\PYGZus{}state, sent);}
\PYG{l+s}{    events\PYGZsq{} = events @ [(proc, event)];}
\PYG{l+s}{    msgs\PYGZsq{} = msgs ∪ ((λmsg. (proc, msg)) ` sent);}
\PYG{l+s}{    states\PYGZsq{} = states (proc := new\PYGZus{}state)}
\PYG{l+s}{   ⟧ ⟹ execute step init procs events\PYGZsq{} msgs\PYGZsq{} states\PYGZsq{}\PYGZdq{}}

\PYG{k+kn}{inductive\PYGZus{}cases}\PYG{+w}{ }\PYG{n}{execute\PYGZus{}indcases}\PYG{o}{:}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}execute step init procs events msg states\PYGZdq{}}

